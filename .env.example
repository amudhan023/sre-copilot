# SRE Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is required to run the demo.

# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Kafka (defaults work with docker-compose) ────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sre_copilot
POSTGRES_USER=sre_user
POSTGRES_PASSWORD=sre_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── Observability ────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# ─── Email (Mailhog for local demo) ───────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
EMAIL_FROM=sre-copilot@company.com
ONCALL_EMAIL=oncall@company.com
TEAM_EMAIL=sre-team@company.com
MANAGEMENT_EMAIL=engineering-management@company.com

# ─── Embedding (sentence-transformers, no API key needed) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Simulation tuning ────────────────────────────────────────────────────────
INITIAL_QUIET_PERIOD_SECONDS=60
FAILURE_GAP_MIN_SECONDS=300
FAILURE_GAP_MAX_SECONDS=600

# ─── Detection tuning ─────────────────────────────────────────────────────────
SIGMA_THRESHOLD=2.5
DEDUP_TTL_SECONDS=300
